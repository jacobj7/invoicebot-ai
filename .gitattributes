# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.c text
*.h text
*.cpp text
*.hpp text
*.py text
*.js text
*.ts text
*.jsx text
*.tsx text
*.json text
*.xml text
*.yaml text
*.yml text
*.toml text
*.ini text
*.cfg text
*.conf text
*.md text
*.txt text
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf
*.fish text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
