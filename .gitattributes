# Merge strategies
# Use union merge strategy for lock files to reduce conflicts
package-lock.json merge=union
yarn.lock merge=union
Gemfile.lock merge=union
Pipfile.lock merge=union
poetry.lock merge=union
Cargo.lock merge=union
composer.lock merge=union
pnpm-lock.yaml merge=union
go.sum merge=union

